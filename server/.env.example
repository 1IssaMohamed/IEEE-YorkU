# Server Configuration
PORT=5000

# CORS (optional in production)
# ALLOWED_ORIGIN=https://your-frontend-domain.example

# SMTP mail configuration (required for invite emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="IEEE YorkU <your-email@gmail.com>"

# Discord invite configuration (required)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-discord-channel-id
DISCORD_INVITE_MAX_AGE=86400

# Important: keep real secrets in server/.env only and never commit them.
